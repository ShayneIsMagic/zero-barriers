# Environment Variables Template
# Copy this file to .env.local and update with your actual values
# DO NOT commit .env.local to git (it's in .gitignore)

# ============================================
# Google Analytics Configuration
# ============================================
# These IDs are from your Google Analytics account: https://analytics.google.com/analytics/web/#/a357804074p492485718
# Add these to Cloudflare Pages → Settings → Environment Variables for production
NEXT_PUBLIC_GA_ID=G-YHS2Y7L3C9
NEXT_PUBLIC_GTM_ID=GTM-WL8K8XK

# ============================================
# Contact Form Configuration
# ============================================

# Flask backend URL for contact form (REQUIRED)
# Full URL to your form_send_email endpoint
# Local dev: http://localhost:5000/send (or your Flask port)
# Production: https://your-api-domain.com/send
NEXT_PUBLIC_CONTACT_FORM_API_URL=http://localhost:5000/send

# Resend API Key (legacy - not used with Flask backend)
# Get your API key from: https://resend.com/api-keys
# IMPORTANT: Also add this as RESEND_API_KEY in Cloudflare Pages → Settings → Environment Variables
#            Cloudflare Pages Functions need this at runtime (not build time)
RESEND_API_KEY=re_your_resend_api_key_here

# ============================================
# Production Environment Variables (Cloudflare Pages)
# ============================================
# Add these in Cloudflare Dashboard:
# Workers & Pages → zero-barriers → Settings → Environment Variables
#
# REQUIRED for contact form:
# - NEXT_PUBLIC_CONTACT_FORM_API_URL - Full URL to Flask form_send_email endpoint (e.g. https://api.example.com/send)
# REQUIRED for Cloudflare Function (if still used):
# - RESEND_API_KEY (Secret) - Your Resend API key
#
# OPTIONAL:
# - NEXT_PUBLIC_GA_ID - Google Analytics ID (G-YHS2Y7L3C9)
# - NEXT_PUBLIC_GTM_ID - Google Tag Manager ID (GTM-WL8K8XK)
# - CONTACT_EMAIL (Secret) - Override recipient email (defaults to sk@zerobarriers.io)

# ============================================
# Notes
# ============================================
# - .env.local is for local development only
# - Cloudflare Pages Functions run on Cloudflare servers and need environment variables set in the dashboard
# - Variables starting with NEXT_PUBLIC_* are embedded at build time
# - Variables without NEXT_PUBLIC_* are only available at runtime in Cloudflare Functions
